{
  "name": "web-debugger-pw-runner",
  "version": "0.1.0",
  "private": true,
  "description": "Playwright runner that drives Chrome with my-web-debugger extension and consumes Excel test cases.",
  "scripts": {
    "run": "tsx src/runner.ts",
    "run:headed": "HEADLESS=false tsx src/runner.ts",
    "pw:install": "playwright install chromium",
    "pw:ui": "playwright test --ui",
    "pw:codegen": "playwright codegen"
  },
  "dependencies": {
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@types/node": "^24.3.0",
    "tsx": "^4.19.2",
    "typescript": "^5.9.2"
  }
}
