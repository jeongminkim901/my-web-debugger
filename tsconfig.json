{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "lib": ["ES2022", "DOM"],
    "allowJs": false,
    "checkJs": false,
    "strict": false,
    "skipLibCheck": true,
    "types": ["chrome", "node", "vitest/globals"],
    "esModuleInterop": true,
    "rootDir": "src",
    "outDir": "dist"
  },
  "include": ["src/**/*.ts"],
  "exclude": ["tests/**/*.ts", "node_modules"]
}
